{
  "name": "tree-generator-dldyou",
  "displayName": "Tree Generator",
  "description": "Generate project tree for README.md",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "bin": {
    "tree-generator": "./out/cli.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "tree-generator.generateTree",
        "title": "Tree Generator: Open Tree Editor"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.21",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "ignore": "^7.0.5"
  },
  "readme": "./README.md",
  "publisher": "dldyou"
}
